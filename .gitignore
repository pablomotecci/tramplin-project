# ============================================================
# .gitignore для монорепозитория (Backend + Frontend)
# ============================================================

# === БЭКЕНД (tramplin-backend) ===
tramplin-backend/target/
tramplin-backend/.idea/
build/
*.class
*.jar
*.war

# === ФРОНТЕНД (frontend) ===
frontend/node_modules/
frontend/dist/
frontend/build/
frontend/.npm/

# === СЕКРЕТЫ И ПЕРЕМЕННЫЕ ===
# Игнорируем везде, чтобы не утекли пароли
.env
.env.properties
.env.local
.env.development
.env.test
.env.production

# === IDE И НАСТРОЙКИ ===
.idea/
*.iml
.vscode/
*.swp
.settings/
.project
.classpath

# === ЛОГИ ===
*.log
logs/

# === ЗАГРУЗКИ И ДАННЫЕ ===
uploads/
postgres_data/
pgdata/

# === OS ===
.DS_Store
Thumbs.db